DATABASE_URL=postgresql://rocket:password@localhost:5434/rocket
ROCKET_DATA_DIR=/path/to/retailrocket
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=reco-artifacts
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Production DB TLS
POSTGRES_TLS_SERVER_CERT_PATH=./ops/tls/postgres/server.crt
POSTGRES_TLS_SERVER_KEY_PATH=./ops/tls/postgres/server.key
POSTGRES_TLS_CA_CERT_PATH=./ops/tls/postgres/ca.crt

# Backup encryption drill
BACKUP_ENCRYPTION_PASSPHRASE=replace_with_strong_secret
